# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real values.
#
# All variables below are consumed by helper scripts under scripts/.
# The exporter CLI itself (`npm run dev -- export <url>`) takes its URL on the
# command line and does not read .env.

# ---- Source site (the LIVE Framer site you are exporting) ---------------------
# Used by:  scripts/compareLiveVsLocal.ts, scripts/diagnoseMobileBug.ts
LIVE_URL=https://your-site.framer.website/

# ---- Local serve URL (where `npm run serve` exposes the export) --------------
# Used by:  scripts/compareLiveVsLocal.ts, scripts/diagnoseMobileBug.ts, scripts/verifyExport.ts
LOCAL_URL=http://localhost:3000/

# ---- Cloudflare Pages deployment ---------------------------------------------
# Used by:  scripts/verifyAccess.ts and any deploy commands you script later.
# Project name is what you pass to `wrangler pages deploy ... --project-name <name>`.
CF_PAGES_PROJECT=your-project
DEPLOY_URL=https://your-project.pages.dev/

# ---- Cloudflare account & API token (Access policy / Zero Trust automation) -
# CF_ACCOUNT_ID is your numeric account id (visible in the dashboard URL).
# CF_TOKEN must be a custom API token with `Account / Access: Apps and Policies / Edit`
# (and Read on Organizations) — wrangler's OAuth token does NOT include those scopes.
# Create at: https://dash.cloudflare.com/profile/api-tokens
CF_ACCOUNT_ID=
CF_TOKEN=

# ---- Access policy (the email allowlist applied by scripts/setupAccess.ts) ---
# Comma-separated. Use email_domain syntax `@example.com` to allow whole domains.
ACCESS_ALLOWED=owner@example.com,@example.com
