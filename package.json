{
  "name": "framer-exporter",
  "version": "0.1.0",
  "description": "Download a published or preview Framer site and output a fully-decoupled static website.",
  "type": "module",
  "bin": {
    "framer-exporter": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "serve": "sirv output --port 3000 --single",
    "typecheck": "tsc --noEmit",
    "postinstall": "playwright install chromium --with-deps || playwright install chromium"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "mime-types": "^2.1.35",
    "p-queue": "^8.0.1",
    "parse-srcset": "^1.0.2",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "playwright": "^1.48.0",
    "postcss": "^8.4.47",
    "postcss-url": "^10.1.3",
    "sirv-cli": "^2.0.2"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.16.10",
    "@types/parse-srcset": "^1.0.0",
    "@types/postcss-url": "^10.0.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
